<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TinyBench</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Iosevka+Charon:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --background-primary: #202020;
      --background-primary-alt: #1a1a1a;
      --background-secondary: #161616;
      --background-secondary-alt: #0f0f0f;
      --background-modifier-border: #363636;
      --background-modifier-hover: #2a2a2a;
      --text-normal: #dcddde;
      --text-muted: #999999;
      --text-faint: #666666;
      --text-accent: #a48cf2;
      --text-accent-hover: #b9a7ff;
      --interactive-accent: #7f6df2;
      --green: #70c27e;
      --yellow: #d6b96d;
      --red: #ff6b6b;
      --line: #2b2b2b;
    }

    * { box-sizing: border-box; }
    html {
      background: var(--background-secondary-alt);
      color: var(--text-normal);
      font-family: "Iosevka Charon", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      letter-spacing: 0;
    }
    body { margin: 0; min-height: 100vh; background: var(--background-primary); }
    a { color: var(--text-accent); text-decoration-thickness: 1px; text-underline-offset: 4px; }
    a:hover { color: var(--text-accent-hover); }
    button, input, select { font: inherit; }
    h1, h2, h3, p { margin: 0; }
    h1 { font-size: 20px; line-height: 1.1; font-weight: 700; overflow-wrap: anywhere; }
    .topbar {
      position: sticky;
      top: 0;
      z-index: 10;
      border-bottom: 1px solid var(--background-modifier-border);
      background: rgba(32, 32, 32, 0.96);
      backdrop-filter: blur(14px);
    }
    .topbar-inner, .shell { width: 100%; max-width: 72rem; margin-inline: auto; padding-inline: 16px; }
    .topbar-inner {
      min-height: 68px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }
    .shell { padding-block: 28px 48px; }
    .brand { display: flex; align-items: center; gap: 10px; min-width: 0; }
    .nav { display: flex; align-items: center; gap: 14px; font-size: 13px; }
    .mark {
      display: grid;
      place-items: center;
      width: 30px;
      height: 30px;
      border: 1px solid var(--background-modifier-border);
      border-radius: 6px;
      background: var(--background-secondary);
      color: var(--text-accent);
      font-weight: 700;
    }
    .subtle { color: var(--text-muted); font-size: 13px; line-height: 1.4; }
    .toolbar { display: flex; align-items: center; justify-content: flex-end; gap: 8px; flex-wrap: wrap; }
    .control {
      height: 36px;
      border: 1px solid var(--background-modifier-border);
      border-radius: 7px;
      background: var(--background-secondary);
      color: var(--text-normal);
      outline: none;
    }
    .control:hover { border-color: var(--interactive-accent); }
    .search { width: min(320px, 52vw); padding: 0 10px; }
    .select { padding: 0 30px 0 10px; }
    .layout { display: grid; gap: 16px; }
    .panel {
      border: 1px solid var(--background-modifier-border);
      border-radius: 8px;
      background: var(--background-secondary);
      min-width: 0;
      overflow: hidden;
    }
    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px;
      border-bottom: 1px solid var(--background-modifier-border);
      background: var(--background-primary-alt);
    }
    .runs-head { align-items: flex-start; flex-wrap: wrap; }
    .panel-title { font-size: 14px; font-weight: 700; color: var(--text-normal); overflow-wrap: anywhere; }
    .leaderboard, .run-list { display: grid; }
    .leader, .run-row { padding: 14px; border-bottom: 1px solid var(--line); }
    .leader:last-child, .run-row:last-child { border-bottom: 0; }
    .leader { display: grid; grid-template-columns: 28px minmax(0, 1fr) auto; gap: 10px; align-items: center; }
    .rank { color: var(--text-faint); font-size: 13px; }
    .bar-track { height: 6px; margin-top: 7px; border-radius: 999px; background: var(--background-primary); overflow: hidden; }
    .bar { height: 100%; border-radius: inherit; background: var(--interactive-accent); }
    .run-title { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; margin-bottom: 6px; }
    .repo, .model { color: var(--text-normal); font-weight: 700; overflow-wrap: anywhere; }
    .repo { font-size: 16px; }
    .pill {
      display: inline-flex;
      align-items: center;
      min-height: 22px;
      max-width: 100%;
      padding: 2px 7px;
      border: 1px solid var(--background-modifier-border);
      border-radius: 999px;
      background: var(--background-primary-alt);
      color: var(--text-muted);
      font-size: 12px;
      line-height: 1.3;
      overflow-wrap: anywhere;
    }
    .docs, .remark { color: var(--text-muted); line-height: 1.45; white-space: pre-wrap; overflow-wrap: anywhere; }
    .links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px; font-size: 13px; }
    .score {
      display: inline-grid;
      place-items: center;
      min-width: 34px;
      height: 28px;
      border-radius: 6px;
      color: var(--background-secondary-alt);
      font-weight: 700;
      flex: 0 0 auto;
    }
    .score.good { background: var(--green); }
    .score.mid { background: var(--yellow); }
    .score.bad { background: var(--red); }
    .run-meta { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px; }
    .empty { padding: 28px 14px; color: var(--text-muted); text-align: center; line-height: 1.45; }
    .footer {
      padding-top: 22px;
      color: var(--text-muted);
      font-size: 13px;
      text-align: center;
    }

    @media (max-width: 920px) {
      .topbar-inner { align-items: stretch; flex-direction: column; padding-block: 14px; }
      .toolbar { justify-content: flex-start; }
    }
    @media (max-width: 620px) {
      .topbar-inner, .shell { padding-inline: 10px; }
      .search, .select { width: 100%; }
      .toolbar { width: 100%; }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <div class="mark">tb</div>
        <div>
          <h1>TinyBench</h1>
        </div>
      </div>
      <nav class="nav" aria-label="Primary">
        <a href="../index.html">Tiny Eval</a>
      </nav>
    </div>
  </header>

  <main class="shell">
    <section class="layout">
      <aside class="panel">
        <div class="panel-head">
          <h2 class="panel-title">Leaderboard</h2>
          <div class="subtle">avg rating</div>
        </div>
        <div id="leaderboard" class="leaderboard"></div>
      </aside>

      <div class="panel">
        <div class="panel-head runs-head">
          <div>
            <h2 class="panel-title">Runs</h2>
            <div id="runCount" class="subtle">0 runs</div>
          </div>
          <div class="toolbar">
            <input id="search" class="control search" type="search" placeholder="Filter runs">
            <select id="modelFilter" class="control select" aria-label="Filter by model">
              <option value="">All models</option>
            </select>
            <select id="ratingFilter" class="control select" aria-label="Filter by rating">
              <option value="">All ratings</option>
              <option value="good">8-10</option>
              <option value="mid">5-7</option>
              <option value="bad">0-4</option>
            </select>
            <select id="sort" class="control select" aria-label="Sort runs">
              <option value="rating-desc">Best rating</option>
              <option value="rating-asc">Worst rating</option>
              <option value="repo">Repository</option>
              <option value="model">Model</option>
            </select>
          </div>
        </div>
        <div id="runs" class="run-list"></div>
      </div>
    </section>
    <footer class="footer">
      <a href="https://vivek.ink">vivek.ink</a>
    </footer>
  </main>

  <script>
    const dashboard = {{ dashboardJson | safe }};
    const state = { query: "", model: "", rating: "", sort: "rating-desc" };
    const els = {
      search: document.querySelector("#search"),
      modelFilter: document.querySelector("#modelFilter"),
      ratingFilter: document.querySelector("#ratingFilter"),
      sort: document.querySelector("#sort"),
      runCount: document.querySelector("#runCount"),
      runs: document.querySelector("#runs"),
      leaderboard: document.querySelector("#leaderboard"),
    };

    populateModelFilter();
    els.search.addEventListener("input", () => {
      state.query = els.search.value.trim().toLowerCase();
      render();
    });
    els.modelFilter.addEventListener("change", () => {
      state.model = els.modelFilter.value;
      render();
    });
    els.ratingFilter.addEventListener("change", () => {
      state.rating = els.ratingFilter.value;
      render();
    });
    els.sort.addEventListener("change", () => {
      state.sort = els.sort.value;
      render();
    });
    render();

    function render() {
      renderLeaderboard(dashboard.leaderboard || []);
      renderRuns();
    }

    function renderLeaderboard(rows) {
      if (!rows.length) {
        els.leaderboard.innerHTML = `<div class="empty">No evals loaded.</div>`;
        return;
      }
      els.leaderboard.innerHTML = rows.map((row, index) => `
        <div class="leader">
          <div class="rank">${index + 1}</div>
          <div>
            <div class="model">${escapeHtml(row.model)}</div>
            <div class="bar-track"><div class="bar" style="width: ${Math.max(0, Math.min(100, row.average * 10))}%"></div></div>
          </div>
          <div>
            <strong>${Number(row.average).toFixed(1)}</strong>
            <div class="subtle">${row.count} eval${row.count === 1 ? "" : "s"}</div>
          </div>
        </div>
      `).join("");
    }

    function renderRuns() {
      const rows = (dashboard.runs || [])
        .filter((run) => matchesRun(run))
        .sort(runSorter(state.sort));
      els.runCount.textContent = `${rows.length} run${rows.length === 1 ? "" : "s"}`;
      if (!rows.length) {
        els.runs.innerHTML = `<div class="empty">No runs match the current filter.</div>`;
        return;
      }
      els.runs.innerHTML = rows.map((run) => `
        <article class="run-row">
          <div class="run-title">
            <h3 class="repo">${escapeHtml(run.repo)}#${escapeHtml(String(run.prNumber))}</h3>
            <span class="pill">${escapeHtml(run.evalLLM)}</span>
            <span class="score ${scoreClass(run.rating)}">${Number(run.rating).toFixed(0)}</span>
          </div>
          <div class="run-meta">
            <span class="pill">judge ${escapeHtml(run.evalJudgeLLM)}</span>
            <span class="pill">summary ${escapeHtml(run.prSummaryLLM)}</span>
          </div>
          ${run.judgeNotes ? `<p class="remark">${escapeHtml(truncate(run.judgeNotes, 260))}</p>` : ""}
          <div class="links">
            <a href="${escapeAttr(run.detailHref)}">open run</a>
          </div>
        </article>
      `).join("");
    }

    function populateModelFilter() {
      const models = Array.from(new Set((dashboard.runs || []).map((run) => run.evalLLM).filter(Boolean))).sort();
      els.modelFilter.insertAdjacentHTML(
        "beforeend",
        models.map((model) => `<option value="${escapeAttr(model)}">${escapeHtml(model)}</option>`).join(""),
      );
    }

    function matchesRun(run) {
      if (state.model && run.evalLLM !== state.model) return false;
      if (state.rating && scoreClass(run.rating) !== state.rating) return false;
      if (!state.query) return true;
      return [run.repo, run.prNumber, run.evalLLM, run.prSummaryLLM, run.evalJudgeLLM, run.judgeNotes]
        .join(" ")
        .toLowerCase()
        .includes(state.query);
    }

    function runSorter(sort) {
      return (left, right) => {
        if (sort === "rating-asc") return Number(left.rating || 0) - Number(right.rating || 0) || repoCompare(left, right);
        if (sort === "repo") return repoCompare(left, right);
        if (sort === "model") return String(left.evalLLM || "").localeCompare(String(right.evalLLM || "")) || repoCompare(left, right);
        return Number(right.rating || 0) - Number(left.rating || 0) || repoCompare(left, right);
      };
    }

    function repoCompare(left, right) {
      return String(left.repo || "").localeCompare(String(right.repo || "")) ||
        Number(left.prNumber || 0) - Number(right.prNumber || 0);
    }

    function scoreClass(value) {
      if (value >= 8) return "good";
      if (value >= 5) return "mid";
      return "bad";
    }

    function truncate(value, maxLength) {
      const text = String(value || "");
      return text.length > maxLength ? `${text.slice(0, maxLength)}...` : text;
    }

    function escapeHtml(value) {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function escapeAttr(value) {
      return escapeHtml(String(value));
    }
  </script>
</body>
</html>
